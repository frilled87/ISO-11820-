<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/21.0.2"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.iso11820.ui.LoginController"
           stylesheets="@../css/styles.css">
    <VBox alignment="CENTER" maxWidth="380" maxHeight="420"
          styleClass="login-panel">
        <padding>
            <Insets top="36" right="48" bottom="36" left="48"/>
        </padding>
        <spacing>16</spacing>

        <!-- 标题 -->
        <Label text="ISO 11820" styleClass="login-title">
            <font>
                <Font name="Microsoft YaHei" size="26"/>
            </font>
        </Label>
        <Label text="建材不燃性试验仿真系统" styleClass="login-subtitle">
            <font>
                <Font name="Microsoft YaHei" size="13"/>
            </font>
        </Label>

        <!-- 分隔线占位 -->
        <VBox prefHeight="8"/>

        <!-- 角色选择 -->
        <Label text="选择角色" styleClass="field-label">
            <font>
                <Font name="Microsoft YaHei" size="12"/>
            </font>
        </Label>
        <HBox alignment="CENTER" spacing="32"
              styleClass="role-toggle-box">
            <RadioButton fx:id="radioAdmin" text="管 理 员"
                         selected="true" styleClass="role-radio">
                <font>
                    <Font name="Microsoft YaHei" size="13"/>
                </font>
                <toggleGroup>
                    <ToggleGroup fx:id="roleGroup"/>
                </toggleGroup>
            </RadioButton>
            <RadioButton fx:id="radioExperimenter" text="试 验 员"
                         styleClass="role-radio"
                         toggleGroup="$roleGroup">
                <font>
                    <Font name="Microsoft YaHei" size="13"/>
                </font>
            </RadioButton>
        </HBox>

        <!-- 密码输入 -->
        <Label text="访问口令" styleClass="field-label">
            <font>
                <Font name="Microsoft YaHei" size="12"/>
            </font>
        </Label>
        <PasswordField fx:id="passwordField" promptText="请输入密码"
                       prefWidth="260" styleClass="password-field">
            <font>
                <Font name="Microsoft YaHei" size="13"/>
            </font>
        </PasswordField>

        <!-- 按钮区域 -->
        <VBox prefHeight="12"/>
        <HBox alignment="CENTER" spacing="20">
            <Button fx:id="loginButton" text="登 录"
                    prefWidth="110" prefHeight="34"
                    styleClass="login-button"
                    onAction="#handleLogin">
                <font>
                    <Font name="Microsoft YaHei" size="13"/>
                </font>
            </Button>
            <Button fx:id="cancelButton" text="取 消"
                    prefWidth="110" prefHeight="34"
                    styleClass="cancel-button"
                    onAction="#handleCancel">
                <font>
                    <Font name="Microsoft YaHei" size="13"/>
                </font>
            </Button>
        </HBox>
    </VBox>
</StackPane>
