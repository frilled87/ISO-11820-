{
  "Database": {
    "SqlitePath": "Data/ISO11820.db"
  },

  "Hardware": {
    "ConstPower": 2048,
    "PidTemperature": 750,
    "SensorProtocol": "ModbusRtu"
  },

  "Simulation": {
    "EnableSimulation": true,
    "SimulateSensors": true,
    "SimulatePidController": true,
    "InitialFurnaceTemp": 25.0,
    "TargetFurnaceTemp": 750.0,
    "HeatingRatePerSecond": 40.0,
    "TempFluctuation": 0.5,
    "StableThreshold": 3.0,
    "SimulateFlame": false
  },

  "FileStorage": {
    "BaseDirectory": "./ISO11820_Data",
    "TestDataDirectory": "./ISO11820_Data/TestData",
    "CsvEncoding": "UTF-8",
    "CsvDelimiter": ",",
    "CsvLineSeparator": "\n"
  },

  "Report": {
    "OutputDirectory": "./ISO11820_Data/Reports",
    "EnablePdfExport": true,
    "EnableExcelExport": true,
    "EnableCsvAutoSave": true,
    "ExcelSheet1Name": "试验信息",
    "ExcelSheet2Name": "温度数据",
    "ExcelSheet3Name": "温度曲线",
    "PdfPageSize": "A4",
    "ChartWidth": 800,
    "ChartHeight": 400,
    "ReportTitlePrefix": "ISO 11820 不燃性试验报告",
    "ReportFooter": "本报告由 ISO 11820 仿真系统自动生成"
  },

  "Logging": {
    "LogDirectory": "./logs",
    "LogFileName": "iso11820",
    "MaxFileSizeMB": 10,
    "MaxHistoryDays": 30,
    "ConsoleLevel": "INFO",
    "FileLevel": "DEBUG"
  }
}